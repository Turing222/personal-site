---
interface Props {
  title: string;
  description: string;
  href: string;
  date?: Date;
  tags?: string[];
}

const { title, description, href, date, tags = [] } = Astro.props;
const formattedDate = date ? new Intl.DateTimeFormat('zh-CN', { dateStyle: 'medium' }).format(date) : undefined;
---
<a class="entry-card" href={href}>
  <div>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
  <div class="card-meta">
    {formattedDate && <time datetime={date?.toISOString()}>{formattedDate}</time>}
    {tags.slice(0, 3).map((tag) => <span>{tag}</span>)}
  </div>
</a>
