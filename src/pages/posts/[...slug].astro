---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getEntryLang, isPublished, stripLangFromId } from '../../utils/content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter((post) => isPublished(post) && getEntryLang(post) === 'zh')
    .map((post) => ({ params: { slug: stripLangFromId(post.id) }, props: { post } }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<ContentLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  series={post.data.series}
  changelog={post.data.changelog}
  eyebrow="Engineering Note"
  lang="zh"
>
  <Content />
</ContentLayout>
