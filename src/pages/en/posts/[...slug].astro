---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ContentLayout from '../../../layouts/ContentLayout.astro';
import { getEntryLang, stripLangFromId } from '../../../utils/content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter((post) => getEntryLang(post) === 'en')
    .map((post) => ({ params: { slug: stripLangFromId(post.id) }, props: { post } }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<ContentLayout title={post.data.title} description={post.data.description} date={post.data.date} tags={post.data.tags} eyebrow="Engineering Note">
  <Content />
</ContentLayout>
