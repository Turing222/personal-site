---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ContentLayout from '../../../layouts/ContentLayout.astro';
import { getEntryLang, getTranslationUrl, isPublished, stripLangFromId } from '../../../utils/content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter((post) => isPublished(post) && getEntryLang(post) === 'en')
    .map((post) => ({
      params: { slug: stripLangFromId(post.id) },
      props: { post, alternateUrl: getTranslationUrl('posts', post, posts) ?? null },
    }));
}

interface Props {
  post: CollectionEntry<'posts'>;
  alternateUrl: string | null;
}

const { post, alternateUrl } = Astro.props;
const { Content } = await render(post);
---
<ContentLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  updatedDate={post.data.updatedDate}
  tags={post.data.tags}
  series={post.data.series}
  changelog={post.data.changelog}
  eyebrow="Engineering Note"
  lang="en"
  alternateUrl={alternateUrl}
  image={post.data.cover}
>
  <Content />
</ContentLayout>
