---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import { entryUrl, getEntryLang } from '../../utils/content';

const projects = (await getCollection('projects'))
  .filter((project) => getEntryLang(project) === 'en')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const posts = (await getCollection('posts'))
  .filter((post) => getEntryLang(post) === 'en')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredProjects = projects.filter((item) => item.data.featured).slice(0, 3);
const latestPosts = posts.slice(0, 4);
---
<BaseLayout title="Dewflow Lab" description="Personal project lab and technical review archive.">
  <section class="hero-section">
    <p class="eyebrow">Personal Project Lab</p>
    <h1>Project experiments, engineering notes, and technical reviews.</h1>
    <p>Dewflow Lab records project ideas, implementation notes, deployment decisions, backend engineering, databases, AI/RAG practice, and frontend experiments.</p>
    <div class="hero-actions">
      <a class="button primary" href="/en/projects">View Projects</a>
      <a class="button" href="/en/posts">Read Posts</a>
      <a class="button" href="/">中文</a>
    </div>
  </section>

  <section class="section-grid">
    <div class="section-heading">
      <p class="eyebrow">Featured</p>
      <h2>Featured Projects</h2>
    </div>
    <div class="card-grid">
      {featuredProjects.map((project) => (
        <EntryCard title={project.data.title} description={project.data.description} href={entryUrl('projects', project)} date={project.data.date} tags={project.data.tags} />
      ))}
    </div>
  </section>

  <section class="section-grid">
    <div class="section-heading">
      <p class="eyebrow">Latest</p>
      <h2>Latest Posts</h2>
    </div>
    <div class="list-grid">
      {latestPosts.map((post) => (
        <EntryCard title={post.data.title} description={post.data.description} href={entryUrl('posts', post)} date={post.data.date} tags={post.data.tags} />
      ))}
    </div>
  </section>
</BaseLayout>
