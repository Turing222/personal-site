---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import HeroField from '../../components/HeroField.astro';
import { entryUrl, getEntryLang, isPublished } from '../../utils/content';

const projects = (await getCollection('projects'))
  .filter((project) => isPublished(project) && getEntryLang(project) === 'en')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const posts = (await getCollection('posts'))
  .filter((post) => isPublished(post) && getEntryLang(post) === 'en')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredProjects = projects.filter((item) => item.data.featured).slice(0, 3);
const latestPosts = posts.slice(0, 4);
---
<BaseLayout title="Dewflow Lab" description="Personal project lab and technical review archive." htmlClass="section-scroll-page">
  <section id="home-intro" class="hero-section hero-with-field tracked-section" data-section-id>
    <HeroField />
    <div class="hero-content">
      <p class="eyebrow">Personal Project Lab</p>
      <h1>Project experiments, engineering notes, and technical reviews.</h1>
      <p>Dewflow Lab records project ideas, implementation notes, deployment decisions, backend engineering, databases, AI/RAG practice, and frontend experiments.</p>
      <div class="hero-actions">
        <a class="button primary" href="/en/projects">View Projects</a>
        <a class="button" href="/en/posts">Read Posts</a>
        <a class="button" href="/">中文</a>
      </div>
    </div>
  </section>

  <section id="featured-projects" class="section-grid tracked-section" data-section-id>
    <div class="section-heading">
      <p class="eyebrow">Featured</p>
      <h2>Featured Projects</h2>
    </div>
    <div class="card-grid">
      {featuredProjects.map((project) => (
        <EntryCard title={project.data.title} description={project.data.description} href={entryUrl('projects', project)} date={project.data.date} updatedDate={project.data.updatedDate} tags={project.data.tags} series={project.data.series} lang="en" />
      ))}
    </div>
  </section>

  <section id="latest-notes" class="section-grid tracked-section" data-section-id>
    <div class="section-heading">
      <p class="eyebrow">Latest</p>
      <h2>Latest Posts</h2>
    </div>
    <div class="list-grid">
      {latestPosts.map((post) => (
        <EntryCard title={post.data.title} description={post.data.description} href={entryUrl('posts', post)} date={post.data.date} updatedDate={post.data.updatedDate} tags={post.data.tags} series={post.data.series} lang="en" />
      ))}
    </div>
  </section>

  <nav class="section-dots" aria-label="Homepage sections" data-section-nav>
    <a class="active" href="#home-intro" aria-label="Intro" aria-current="true" data-section-link></a>
    <a href="#featured-projects" aria-label="Featured projects" data-section-link></a>
    <a href="#latest-notes" aria-label="Latest notes" data-section-link></a>
  </nav>
</BaseLayout>
