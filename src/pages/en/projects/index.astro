---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryCard from '../../../components/EntryCard.astro';
import { entryUrl, getEntryLang, isPublished } from '../../../utils/content';

const projects = (await getCollection('projects'))
  .filter((project) => isPublished(project) && getEntryLang(project) === 'en')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Project Reviews" description="Project experiments, technical choices, and retrospectives.">
  <section class="page-header">
    <p class="eyebrow">Projects</p>
    <h1>Project Reviews</h1>
    <p>Each review records context, goals, technical approach, tradeoffs, results, and retrospective notes.</p>
  </section>
  <section class="list-grid">
    {projects.map((project) => (
      <EntryCard title={project.data.title} description={project.data.description} href={entryUrl('projects', project)} date={project.data.date} updatedDate={project.data.updatedDate} tags={project.data.tags} series={project.data.series} lang="en" />
    ))}
  </section>
</BaseLayout>
