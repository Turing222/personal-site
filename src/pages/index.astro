---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import { entryUrl, getEntryLang } from '../utils/content';

const projects = (await getCollection('projects'))
  .filter((project) => getEntryLang(project) === 'zh')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const posts = (await getCollection('posts'))
  .filter((post) => getEntryLang(post) === 'zh')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredProjects = projects.filter((item) => item.data.featured).slice(0, 3);
const latestPosts = posts.slice(0, 4);
---
<BaseLayout>
  <section class="hero-section">
    <p class="eyebrow">Personal Project Lab</p>
    <h1>个人项目实验室与技术复盘档案。</h1>
    <p>Dewflow Lab 用来记录项目从想法、实现、部署到复盘的过程，也沉淀后端工程、数据库、AI/RAG 和前端实验相关笔记。</p>
    <div class="hero-actions">
      <a class="button primary" href="/projects">查看项目</a>
      <a class="button" href="/posts">阅读笔记</a>
      <a class="button" href="/search">搜索内容</a>
    </div>
  </section>

  <section class="section-grid">
    <div class="section-heading">
      <p class="eyebrow">Featured</p>
      <h2>精选项目</h2>
    </div>
    <div class="card-grid">
      {featuredProjects.map((project) => (
        <EntryCard
          title={project.data.title}
          description={project.data.description}
          href={entryUrl('projects', project)}
          date={project.data.date}
          tags={project.data.tags}
        />
      ))}
    </div>
  </section>

  <section class="section-grid">
    <div class="section-heading">
      <p class="eyebrow">Latest</p>
      <h2>最新笔记</h2>
    </div>
    <div class="list-grid">
      {latestPosts.map((post) => (
        <EntryCard
          title={post.data.title}
          description={post.data.description}
          href={entryUrl('posts', post)}
          date={post.data.date}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
