---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import HeroField from '../components/HeroField.astro';
import { entryUrl, getEntryLang, isPublished } from '../utils/content';

const projects = (await getCollection('projects'))
  .filter((project) => isPublished(project) && getEntryLang(project) === 'zh')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const posts = (await getCollection('posts'))
  .filter((post) => isPublished(post) && getEntryLang(post) === 'zh')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredProjects = projects.filter((item) => item.data.featured).slice(0, 3);
const latestPosts = posts.slice(0, 4);
---
<BaseLayout htmlClass="section-scroll-page">
  <section id="home-intro" class="hero-section hero-with-field tracked-section" data-section-id>
    <HeroField />
    <div class="hero-content">
      <p class="eyebrow">Personal Project Lab</p>
      <h1>个人项目实验室与技术复盘档案</h1>
      <p>Dewflow Lab 用来记录项目从想法、实现、部署到复盘的过程，也沉淀后端工程、数据库、AI/RAG 和前端实验相关笔记。</p>
      <div class="hero-actions">
        <a class="button primary" href="/projects">查看项目</a>
        <a class="button" href="/posts">阅读笔记</a>
        <a class="button" href="/search">搜索内容</a>
      </div>
    </div>
  </section>

  <section id="featured-projects" class="section-grid tracked-section" data-section-id>
    <div class="section-heading">
      <p class="eyebrow">Featured</p>
      <h2>精选项目</h2>
    </div>
    <div class="card-grid">
      {featuredProjects.map((project) => (
        <EntryCard
          title={project.data.title}
          description={project.data.description}
          href={entryUrl('projects', project)}
          date={project.data.date}
          updatedDate={project.data.updatedDate}
          tags={project.data.tags}
          series={project.data.series}
          lang="zh"
        />
      ))}
    </div>
  </section>

  <section id="latest-notes" class="section-grid tracked-section" data-section-id>
    <div class="section-heading">
      <p class="eyebrow">Latest</p>
      <h2>最新笔记</h2>
    </div>
    <div class="list-grid">
      {latestPosts.map((post) => (
        <EntryCard
          title={post.data.title}
          description={post.data.description}
          href={entryUrl('posts', post)}
          date={post.data.date}
          updatedDate={post.data.updatedDate}
          tags={post.data.tags}
          series={post.data.series}
          lang="zh"
        />
      ))}
    </div>
  </section>

  <nav class="section-dots" aria-label="首页分区" data-section-nav>
    <a class="active" href="#home-intro" aria-label="Intro" aria-current="true" data-section-link></a>
    <a href="#featured-projects" aria-label="Featured projects" data-section-link></a>
    <a href="#latest-notes" aria-label="Latest notes" data-section-link></a>
  </nav>
</BaseLayout>
