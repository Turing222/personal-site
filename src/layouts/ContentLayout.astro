---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
  series?: string;
  changelog?: Array<{ date: Date; note: string }>;
  eyebrow?: string;
  lang?: 'zh' | 'en';
  alternateUrl?: string | null;
  image?: string;
}

const {
  title,
  description,
  date,
  updatedDate,
  tags = [],
  series,
  changelog = [],
  eyebrow = 'Note',
  lang = 'zh',
  alternateUrl,
  image,
} = Astro.props;
const locale = lang === 'en' ? 'en-US' : 'zh-CN';
const formatter = new Intl.DateTimeFormat(locale, { dateStyle: 'medium' });
const formattedDate = formatter.format(date);
const hasUpdatedDate = updatedDate && updatedDate.toDateString() !== date.toDateString();
const formattedUpdatedDate = hasUpdatedDate ? formatter.format(updatedDate) : undefined;
const labels = lang === 'en'
  ? { published: 'Published', updated: 'Updated', series: 'Series', changelog: 'Changelog' }
  : { published: '发布于', updated: '更新于', series: '系列', changelog: '更新记录' };
---
<BaseLayout title={title} description={description} type="article" alternateUrl={alternateUrl} image={image}>
  <article class="content-shell" lang={lang === 'en' ? 'en' : 'zh-CN'}>
    <header class="content-hero">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p>{description}</p>
      <div class="meta-row">
        <time datetime={date.toISOString()}>{labels.published} {formattedDate}</time>
        {hasUpdatedDate && <time class="meta-updated" datetime={updatedDate.toISOString()}>{labels.updated} {formattedUpdatedDate}</time>}
        {series && <span>{labels.series}: {series}</span>}
        {tags.map((tag) => <span>{tag}</span>)}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
    {changelog.length > 0 && (
      <section class="content-changelog" aria-labelledby="content-changelog-title">
        <h2 id="content-changelog-title">{labels.changelog}</h2>
        <ol class="timeline">
          {changelog.map((item) => (
            <li>
              <time datetime={item.date.toISOString()}>{formatter.format(item.date)}</time>
              <span>{item.note}</span>
            </li>
          ))}
        </ol>
      </section>
    )}
  </article>
</BaseLayout>
