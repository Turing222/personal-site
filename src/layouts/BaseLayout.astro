---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  htmlClass?: string;
  image?: string;
  type?: 'website' | 'article';
  alternateUrl?: string | null;
}

const siteName = 'Dewflow Lab';
const {
  title = siteName,
  description = '个人项目实验室与技术复盘档案。',
  htmlClass = '',
  image = '/images/og-default.png',
  type = 'website',
  alternateUrl,
} = Astro.props;
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const isEnglish = Astro.url.pathname.startsWith('/en');
const navPrefix = isEnglish ? '/en' : '';
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

// Alternate resolution: undefined = naive prefix swap (static pages with mirrors),
// null = no counterpart exists, string = explicit URL from the page.
const autoAlternate = isEnglish
  ? Astro.url.pathname.replace(/^\/en\/?/, '/')
  : `/en${Astro.url.pathname === '/' ? '/' : Astro.url.pathname}`;
const resolvedAlternate = alternateUrl === undefined ? autoAlternate : alternateUrl;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(image, Astro.site);
const alternateAbsUrl = resolvedAlternate ? new URL(resolvedAlternate, Astro.site) : undefined;
const zhUrl = isEnglish ? alternateAbsUrl : canonicalUrl;
const enUrl = isEnglish ? canonicalUrl : alternateAbsUrl;
const ogLocale = isEnglish ? 'en_US' : 'zh_CN';
const ogLocaleAlternate = isEnglish ? 'zh_CN' : 'en_US';
const rssHref = isEnglish ? '/en/rss.xml' : '/rss.xml';
const rssTitle = isEnglish ? `${siteName} (English)` : `${siteName} (中文)`;

const switchHref = resolvedAlternate ?? (isEnglish ? '/' : '/en/');
const switchLabel = isEnglish ? '中文' : 'EN';
const navItems = [
  { href: `${navPrefix}/projects`, label: 'Projects', match: `${navPrefix}/projects` },
  { href: `${navPrefix}/posts`, label: 'Posts', match: `${navPrefix}/posts` },
  { href: `${navPrefix}/updates`, label: 'Updates', match: `${navPrefix}/updates` },
  { href: `${navPrefix}/tags`, label: 'Tags', match: `${navPrefix}/tags` },
  { href: `${navPrefix}/search`, label: 'Search', match: `${navPrefix}/search` },
  { href: '/lab', label: 'Lab', match: '/lab' },
  { href: `${navPrefix}/about`, label: 'About', match: `${navPrefix}/about` },
];

function isCurrentNavItem(match: string) {
  const normalizedMatch = match.replace(/\/$/, '') || '/';
  return currentPath === normalizedMatch || currentPath.startsWith(`${normalizedMatch}/`);
}
---
<!doctype html>
<html lang={isEnglish ? 'en' : 'zh-CN'} class={htmlClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    {zhUrl && enUrl && (
      <>
        <link rel="alternate" hreflang="zh-CN" href={zhUrl} />
        <link rel="alternate" hreflang="en" href={enUrl} />
        <link rel="alternate" hreflang="x-default" href={zhUrl} />
      </>
    )}
    <link rel="alternate" type="application/rss+xml" title={rssTitle} href={rssHref} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    {alternateAbsUrl && <meta property="og:locale:alternate" content={ogLocaleAlternate} />}
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-gb-web@1.522.0/lxgwwenkaigb-regular/result.css"
    />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <header class="site-header" data-site-header>
      <div class="site-header-inner">
        <a class="brand" href="/">Dewflow Lab</a>
        <nav class="site-nav" aria-label="Primary navigation">
          {navItems.map((item) => (
            <a href={item.href} aria-current={isCurrentNavItem(item.match) ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
          <a href={switchHref}>{switchLabel}</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>Dewflow Lab</span>
      <span>Built with Astro, MDX and Cloudflare Pages.</span>
    </footer>
    <script>
      import '../scripts/mermaid';
      import '../scripts/header';
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
