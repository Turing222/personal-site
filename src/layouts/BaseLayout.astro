---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  htmlClass?: string;
}

const siteName = 'Dewflow Lab';
const { title = siteName, description = '个人项目实验室与技术复盘档案。', htmlClass = '' } = Astro.props;
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const isEnglish = Astro.url.pathname.startsWith('/en');
const navPrefix = isEnglish ? '/en' : '';
const switchHref = isEnglish ? '/' : '/en/';
const switchLabel = isEnglish ? '中文' : 'EN';
---
<!doctype html>
<html lang={isEnglish ? 'en' : 'zh-CN'} class={htmlClass}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Dewflow Lab</a>
      <nav aria-label="Primary navigation">
        <a href={`${navPrefix}/projects`}>Projects</a>
        <a href={`${navPrefix}/posts`}>Posts</a>
        <a href={`${navPrefix}/updates`}>Updates</a>
        <a href={`${navPrefix}/tags`}>Tags</a>
        <a href={`${navPrefix}/search`}>Search</a>
        <a href="/lab">Lab</a>
        <a href={`${navPrefix}/about`}>About</a>
        <a href={switchHref}>{switchLabel}</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>Dewflow Lab</span>
      <span>Built with Astro, MDX and Cloudflare Pages.</span>
    </footer>
    <script>
      import mermaid from 'mermaid';

      mermaid.initialize({
        startOnLoad: false,
        theme: 'dark',
      });

      let sectionDotResizeHandler;
      let sectionDotScrollHandler;
      let sectionDotAbortController;

      async function renderMermaidBlocks() {
        const blocks = Array.from(document.querySelectorAll('pre[data-language="mermaid"]'));
        blocks.forEach((block, index) => {
          const container = document.createElement('div');
          const lines = Array.from(block.querySelectorAll('.line'));
          container.className = 'mermaid';
          container.id = `mermaid-${index}`;
          container.dataset.mermaidPending = 'true';
          container.textContent = lines.length > 0
            ? lines.map((line) => line.textContent ?? '').join('\n')
            : block.textContent ?? '';
          block.replaceWith(container);
        });

        if (blocks.length > 0) {
          await mermaid.run({ querySelector: '.mermaid[data-mermaid-pending="true"]' });
          document.querySelectorAll('.mermaid[data-mermaid-pending="true"]').forEach((block) => {
            block.removeAttribute('data-mermaid-pending');
          });
        }
      }

      function setupSectionDots() {
        if (sectionDotResizeHandler) {
          window.removeEventListener('resize', sectionDotResizeHandler);
          sectionDotResizeHandler = undefined;
        }
        if (sectionDotScrollHandler) {
          window.removeEventListener('scroll', sectionDotScrollHandler);
          window.removeEventListener('resize', sectionDotScrollHandler);
          sectionDotScrollHandler = undefined;
        }
        if (sectionDotAbortController) {
          sectionDotAbortController.abort();
          sectionDotAbortController = undefined;
        }

        const nav = document.querySelector('[data-section-nav]');
        const sections = Array.from(document.querySelectorAll('[data-section-id]'));
        const links = Array.from(document.querySelectorAll('[data-section-link]'));
        if (!nav || sections.length === 0 || links.length === 0) {
          return;
        }

        function setRailPosition() {
          const isMediumViewport = window.matchMedia('(min-width: 561px) and (max-width: 900px)').matches;
          nav.setAttribute('style', `left: ${isMediumViewport ? '10px' : '24px'}; right: auto;`);
        }

        function setActive(id) {
          links.forEach((link) => {
            const isActive = link.getAttribute('href') === `#${id}`;
            link.classList.toggle('active', isActive);
            if (isActive) {
              link.setAttribute('aria-current', 'true');
            } else {
              link.removeAttribute('aria-current');
            }
          });
        }

        const hashId = window.location.hash.replace('#', '');
        setRailPosition();
        setActive(hashId || sections[0].id);
        sectionDotResizeHandler = setRailPosition;
        window.addEventListener('resize', sectionDotResizeHandler, { passive: true });

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function updateActiveSection() {
          const viewportCenter = window.innerHeight / 2;
          let nearestSection = sections[0];
          let nearestDistance = Number.POSITIVE_INFINITY;

          sections.forEach((section) => {
            const rect = section.getBoundingClientRect();
            const sectionCenter = rect.top + rect.height / 2;
            const distance = Math.abs(sectionCenter - viewportCenter);
            if (distance < nearestDistance) {
              nearestDistance = distance;
              nearestSection = section;
            }
          });

          if (nearestSection?.id) {
            setActive(nearestSection.id);
          }
        }

        let pendingFrame = 0;
        sectionDotScrollHandler = () => {
          if (pendingFrame) {
            return;
          }
          pendingFrame = window.requestAnimationFrame(() => {
            pendingFrame = 0;
            updateActiveSection();
          });
        };
        window.addEventListener('scroll', sectionDotScrollHandler, { passive: true });
        window.addEventListener('resize', sectionDotScrollHandler, { passive: true });

        sectionDotAbortController = new AbortController();
        links.forEach((link) => {
          link.addEventListener('click', (event) => {
            const href = link.getAttribute('href');
            if (!href?.startsWith('#')) {
              return;
            }

            const target = document.getElementById(href.slice(1));
            if (!target) {
              return;
            }

            event.preventDefault();
            setActive(target.id);
            history.replaceState(null, '', href);
            target.scrollIntoView({
              behavior: prefersReducedMotion ? 'auto' : 'smooth',
              block: 'start',
            });
          }, { signal: sectionDotAbortController.signal });
        });

        updateActiveSection();
      }

      document.addEventListener('astro:page-load', () => {
        renderMermaidBlocks();
        setupSectionDots();
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
